<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <include layout="@layout/header" />

    <LinearLayout
        android:id="@+id/buttonsContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="10dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button android:id="@+id/btnBalance" style="@style/MeatButton"
            android:text="Заказ по остаткам" />
        <Button android:id="@+id/btnFromScratch" style="@style/MeatButton"
            android:text="Заказ с нуля" />
        <Button android:id="@+id/btnFromTemplate" style="@style/MeatButton"
            android:text="Заказ из шаблона" />
        <Button android:id="@+id/btnTemplates" style="@style/MeatButton"
            android:text="Шаблоны" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
