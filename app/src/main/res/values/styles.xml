<resources>
    <style name="Theme.MeatOrder" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#000000</item>
        <item name="colorOnPrimary">#FFFFFF</item>
    </style>

    <style name="MeatButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">#000000</item>
        <item name="android:background">#FFFFFF</item>
        <item name="cornerRadius">8dp</item>
        <item name="strokeColor">#000000</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:padding">8dp</item>
        <item name="android:layout_margin">8dp</item>
        <!-- Ripple-эффект при нажатии -->
        <item name="rippleColor">#33000000</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">2dp</item>
    </style>
</resources>
